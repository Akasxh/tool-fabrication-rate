\newlabel{tab:anth-temporal}{{2}{5}{Anthropic 4.x distractor probe with target removed ($\mathrm {C}_0$). Pooled $\mathrm {C}_0$ over regime $+$ probe is $0/2{,}592$, $\leq \!0.14\%$; the $\mathrm {C}_1$ subset adds $0/659$ at $\leq \!0.56\%$.\relax }{table.caption.2}{}}
\newlabel{sec:results:probe}{{5.2}{5}{}{subsection.5.2}{}}
\newlabel{sec:results:scaling}{{5.3}{5}{}{subsection.5.3}{}}
\newlabel{fig:scaling}{{1}{6}{Qwen3-family tool-fabrication rate (TFR) under the opaque baseline $\mathrm {C}_0$, four-distractor probe with the target tool removed, $0.6$B--$32$B (per-call pooled; the same data as Table~\ref {tab:qwen3-scale}). Points are pooled per-size TFR; error bars are Clopper--Pearson $95\%$ intervals. The dashed line marks the pooled Anthropic~4.x $\mathrm {C}_0$ upper bound ($0/2{,}592$, $\leq \!0.14\%$; Section~\ref {sec:results:probe}), shown for reference. The shape is non-monotone (near-zero at $0.6$B, a $\sim \!1$--$2\%$ band at $1.7$--$14$B, and $0\%$ at $32$B), but with only six sizes and wide intervals (e.g.\ the $32$B bound overlaps the $14$B estimate) we read it descriptively: a single-family, single-quantization shape, \emph {not} a fitted scaling law and \emph {not} evidence of an emergent capability. Quantization is held at nominal $4$-bit across sizes but not at fixed reconstruction error per checkpoint; we therefore do not attribute the shape to capability alone (see Section~\ref {sec:limitations} and the bf16 control noted there).\relax }{figure.caption.3}{}}
\newlabel{tab:qwen3-scale}{{3}{6}{Qwen3 scaling curve under $\mathrm {C}_0$ (target removed). Cells are events / parsed calls; bold marks the per-row peak.\relax }{table.caption.4}{}}
\newlabel{sec:results:severity}{{5.4}{6}{}{subsection.5.4}{}}
\newlabel{tab:rvr-validation}{{4}{7}{RVR per-tier validation on Qwen3 sizes with non-zero $\mathrm {C}_0$ events. Cells are events / parsed calls. The $\mathrm {C}_0$ column is the full target-removed distractor-probe pool from Table~\ref {tab:qwen3-scale}; $\mathrm {C}_1$ is the registry-visible re-prompt arm.\relax }{table.caption.5}{}}
\newlabel{sec:results:rvr}{{5.5}{7}{}{subsection.5.5}{}}
\newlabel{fig:ablation}{{2}{7}{Qwen3-8B 4-condition ablation. The structured-error envelope ($\mathrm {C}_{0.7}$) already takes TFR to zero; adding the registry list ($\mathrm {C}_1$) yields no further \emph {detectable} reduction (both arms zero-event; see \S \ref {sec:mechanism} for why this bounds rather than proves a format-over-content account).\relax }{figure.caption.6}{}}
\newlabel{sec:results:trace-inspection}{{5.5}{7}{}{figure.caption.6}{}}
\newlabel{sec:results:controls}{{5.6}{7}{}{subsection.5.6}{}}
\newlabel{tab:controls}{{5}{8}{Cross-family and precision controls on the $\mathrm {C}_0$ target-removed probe. Cells are events / parsed calls with TFR and Clopper--Pearson $95\%$ two-sided intervals. Bottom rows are the $\mathrm {C}_1$ RVR arms on Llama and Qwen2.5.\relax }{table.caption.7}{}}
